{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "files": {
    "includes": [
      "src/**/*.ts",
      "src/**/*.html",
      "src/**/*.css",
      "test/**/*.ts",
      "*.json",
      "*.yml",
      "*.yaml",
      "*.md"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  }
}
